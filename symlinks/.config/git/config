[user]
	name = MaxCan-Code
	email = 35848843+MaxCan-Code@users.noreply.github.com
[alias]
	co = checkout
	ss = status
	lg = log --name-status --graph --decorate
	rb = rebase -i --autostash --autosquash
	dt = difftool -y
	dw = diff --color-words
	me = submodule foreach
	pf = push --force-with-lease
[diff]
	colorMoved = dimmed-zebra
	; external = difft
	tool = difft
[difftool "difft"]
	cmd = difft "$LOCAL" "$REMOTE"
[pager]
	difftool = true
[credential "https://github.com"]
	helper =
	helper = /etc/profiles/per-user/user/bin/gh auth git-credential
